# Optional: custom Solana RPC endpoint for wallet adapter reads and confirmations.
# NEXT_PUBLIC_SOLANA_RPC_URL=https://api.mainnet-beta.solana.com

# Admin-provided Adrena competition service for official multiplier lookup,
# health checks, position-schema docs, and live close-position events.
ADRENA_COMPETITION_SERVICE_BASE_URL=https://adrena-competition-service.onrender.com
ADRENA_COMPETITION_SERVICE_WS_BASE_URL=wss://adrena-competition-service.onrender.com
ADRENA_COMPETITION_SERVICE_API_KEY=your-adrena-competition-service-api-key
COMPETITION_SERVICE_WORKER_APP_URL=http://127.0.0.1:3000
# COMPETITION_SERVICE_WORKER_RECONNECT_BASE_MS=1000
# COMPETITION_SERVICE_WORKER_RECONNECT_MAX_MS=15000
# COMPETITION_SERVICE_WORKER_REQUEST_TIMEOUT_MS=30000
# COMPETITION_SERVICE_WORKER_SYNC_ON_CONNECT=true

# Safety default: keep live Adrena transaction submission disabled.
# Set to true only if you intentionally want the trade page to sign and send
# real mainnet transactions with connected wallet funds.
NEXT_PUBLIC_ENABLE_MAINNET_TRADES=false
